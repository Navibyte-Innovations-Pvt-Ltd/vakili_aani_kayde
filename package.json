{
  "name": "template",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack --port 2222",
    "build": "next build && next-sitemap",
    "start": "next start --port 2222",
    "lint": "eslint .",
    "validate": "bun run lint && bun x tsc --noEmit && bun x pruny",
    "postinstall": "bun run prisma generate",
    "prisma:migrate": "bun x prisma migrate dev",
    "prisma:deploy": "bun x prisma migrate deploy",
    "prisma:status": "bun x prisma migrate status",
    "prisma:reset": "bun x prisma migrate reset",
    "prisma:studio": "bun x prisma studio",
    "db:sync": "bun run scripts/db-sync",
    "diagnose": "bun run scripts/diagnose-pending.ts",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run",
    "cy:run:admin": "cypress run --spec 'cypress/e2e/admin/**/*.cy.ts'",
    "cy:run:user": "cypress run --spec 'cypress/e2e/user/**/*.cy.ts'",
    "cy:parallel": "cypress-parallel -s cypress:run -t 4 -d 'cypress/e2e/**/*.cy.ts'",
    "cypress:setup": "tsx cypress/scripts/db-setup.ts",
    "cypress:cleanup": "tsx cypress/scripts/db-cleanup.ts"
  },
